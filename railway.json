{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "uvicorn backend_main:app --host 0.0.0.0 --port $PORT",
    "healthchecks": {
      "readiness": {
        "path": "/health",
        "interval": 10
      }
    }
  }
}
